enum class UacVersion {
    UAC_1_0,
    UAC_2_0
}

enum class FeatureControl {
    MUTE,
    VOLUME,
    BASS,
    MID,
    TREBLE,
    GRAPHIC_EQUALIZER,
    AUTOMATIC_GAIN,
    DELAY,
    BASS_BOOST,
    LOUDNESS,
    INPUT_GAIN,
    INPUT_GAIN_PAD,
    PHASE_INVERTER,
    UNDERFLOW_OVERFLOW,
